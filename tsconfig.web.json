{
    "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
    "include": [
        "src/renderer/src/**/*",
        "src/shared/**/*"
    ],
    "compilerOptions": {
        "jsx": "react-jsx",
        "composite": true,
        "baseUrl": ".",
        "paths": {
            "@renderer/*": [
                "./src/renderer/src/*"
            ],
            "@shared/*": [
                "./src/shared/*"
            ]
        }
    }
}